# Copy this file to .env and fill in your keys
# Never commit .env to GitHub

# Required — Groq API (free at console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# Required — Hugging Face (free at huggingface.co/settings/tokens)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# Required — Tavily web search (free at tavily.com, 1000 searches/month)
TAVILY_API_KEY=tvly_xxxxxxxxxxxxxxxxxxxx

# Optional — MLflow tracking (leave blank to skip tracking)
MLFLOW_TRACKING_URI=http://localhost:5003
